# Multi-Agent Environment Configuration

# Cloud Provider: aws | azure | local
CLOUD_PROVIDER=local

# App
APP_ENV=development
LOG_LEVEL=INFO

# LLM (Ollama local default)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# AWS Bedrock (when CLOUD_PROVIDER=aws)
AWS_REGION=eu-west-1
AWS_BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0

# Azure OpenAI (when CLOUD_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# WebSocket
WS_PORT=8401

# Redis (for task queue and pub/sub)
REDIS_URL=redis://localhost:6379/0

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/multi_agent.db

# Portfolio Integration
GATEWAY_URL=http://localhost:8100
AGENT_URL=http://localhost:8200
MCP_SERVER_URL=http://localhost:8300

# n8n Integration
N8N_WEBHOOK_URL=

# =============================================================================
# Config-tuning labs (Tier 1–5)
# See docs/hands-on-labs/hands-on-labs-config-tuning.md
# App code does not yet read these — wiring them up is part of running each lab.
# =============================================================================

# Tier 1 — Essential
RAG_CHUNK_SIZE=500              # Tokens per chunk (sweep: 200/500/1000)
RAG_CHUNK_OVERLAP=100           # Token overlap between chunks (sweep: 0/100/200)
RAG_TOP_K=5                     # How many chunks to retrieve per query (sweep: 1/3/5/10)
LLM_TEMPERATURE=0.0             # Sampling temperature (sweep: 0.0/0.3/0.7)
SYSTEM_PROMPT_MODE=strict       # strict|lax — controls hallucination strictness
EMBEDDING_DIMENSIONS=1024       # 384/768/1024 — must match embedding model

# Tier 2 — Quality
RERANKER_ENABLED=false          # Re-score retrieved chunks before sending to LLM
RERANKER_MODEL=bge-reranker-base
HYBRID_SEARCH_ENABLED=false     # Combine vector search + BM25 keyword search
HYBRID_ALPHA=0.5                # 0.0=pure keyword, 1.0=pure vector
LLM_MAX_TOKENS=1024             # Max output tokens (sweep: 256/1024/4096)
DISTANCE_METRIC=cosine          # cosine|l2|dot

# Tier 3 — HNSW vector-store tuning
HNSW_M=16                       # Connections per node (sweep: 8/16/32)
HNSW_EF_CONSTRUCTION=200        # Build-time search depth (sweep: 100/200/400)
HNSW_EF_SEARCH=64               # Query-time search depth (sweep: 32/64/128/256)

# Tier 4 — Retrieval strategy
QUERY_REWRITING_ENABLED=false   # Use LLM to rewrite vague queries before search
MULTI_QUERY_COUNT=1             # Generate N query variants and merge (sweep: 1/3/5)
METADATA_FILTERS=               # e.g. source=docs,date>2024-01-01
CHUNK_STRATEGY=fixed            # fixed|semantic|sentence|markdown-aware

# Tier 5 — Evaluation knobs
EVAL_MODE=rule_based            # rule_based|llm_judge
EVAL_FAITHFULNESS_THRESHOLD=0.5 # Min % of grounded sentences to pass (sweep: 0.3/0.5/0.8)
EVAL_KEYWORD_OVERLAP_PCT=0.5    # Strictness of keyword matching in faithfulness scoring

# Agent coordination
AGENT_COUNT=2                   # Number of agents in the crew (sweep: 1/2/4)
AGENT_MAX_ITERATIONS=10         # Max reasoning iterations per agent (sweep: 3/10/25)
